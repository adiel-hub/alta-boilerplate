{
  "name": "alta-boilerplate",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "react-router preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint app/",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:gen-types": "source .env && npx supabase gen types typescript --db-url \"$DATABASE_URL\" > app/lib/supabase/types/database.types.ts",
    "db:new-migration": "npx supabase migration new",
    "db:push": "source .env && npx supabase db push --db-url \"$DATABASE_URL\"",
    "db:diff": "source .env && npx supabase db diff --db-url \"$DATABASE_URL\"",
    "db:reset": "source .env && npx supabase db reset --db-url \"$DATABASE_URL\"",
    "deploy": "vercel",
    "deploy:prod": "vercel --prod"
  },
  "dependencies": {
    "@altahq/design-system": "latest",
    "@react-router/node": "^7.3.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "isbot": "^5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@react-router/dev": "^7.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "supabase": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vercel": "^50.27.1",
    "vite": "^6.1.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
