{
  "name": "@alta/supabase",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "gen-types": "source .env && npx supabase gen types typescript --db-url \"$DATABASE_URL\" > src/types/database.types.ts",
    "db:new-migration": "npx supabase migration new",
    "db:push": "source .env && npx supabase db push --db-url \"$DATABASE_URL\"",
    "db:diff": "source .env && npx supabase db diff --db-url \"$DATABASE_URL\"",
    "db:reset": "source .env && npx supabase db reset --db-url \"$DATABASE_URL\""
  },
  "devDependencies": {
    "@alta/typescript-config": "workspace:*",
    "supabase": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
